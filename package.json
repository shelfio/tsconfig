{
  "name": "@shelf/tsconfig",
  "version": "0.2.0",
  "packageManager": "pnpm@10.32.1",
  "description": "tsconfig",
  "type": "module",
  "license": "MIT",
  "author": {
    "name": "Vlad Holubiev",
    "email": "vlad@shelf.io",
    "url": "https://shelf.io"
  },
  "files": [
    "backend.json",
    "frontend.json"
  ],
  "devDependencies": {
    "@types/node": "20.11.28",
    "husky": "9.1.7",
    "lint-staged": "15.2.7",
    "oxfmt": "0.42.0",
    "typescript": "6.0.2"
  },
  "engines": {
    "node": ">=22.18",
    "pnpm": "10.32.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "format": "oxfmt",
    "lint:ci": "oxfmt --check",
    "test": "pnpm run test:backend && pnpm run test:frontend",
    "test:backend": "tsc --pretty false -p test/fixtures/backend/tsconfig.json --noEmit",
    "test:frontend": "tsc --pretty false -p test/fixtures/frontend/tsconfig.json --noEmit",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{html,json,md,ts,yaml,yml}": "oxfmt"
  }
}
